# AWS Credentials for Deployment
# Copy this to .env.deploy and fill in your values
# These are only needed for running deploy-to-ec2.sh

export AWS_ACCESS_KEY_ID="your-access-key-id"
export AWS_SECRET_ACCESS_KEY="your-secret-access-key"
export AWS_SESSION_TOKEN="your-session-token"  # Only needed for temporary credentials

# Then source it before deploying:
# source .env.deploy
# ./deploy-to-ec2.sh
