{$DOMAIN} {
	# UI — all routes go to Next.js
	reverse_proxy ui:3000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	# Health check
	respond /health 200
}

{$DOMAIN}:8443 {
	# API — separate port for direct API access if needed
	reverse_proxy api:8000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
