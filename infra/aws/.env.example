# === DOMAIN ===
# Set this to your Elastic IP + sslip.io, e.g.: 34.56.78.90.sslip.io
DOMAIN=YOUR_ELASTIC_IP.sslip.io

# === DATABASE (TiDB Cloud — already provisioned) ===
DATABASE_URL=mysql+pymysql://USER:PASS@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/tidboracle?ssl_verify_cert=true&ssl_verify_identity=true

# === LLM ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# === AUTH ===
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
NEXTAUTH_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# === ACCESS CONTROL ===
ALLOWED_EMAIL_DOMAIN=pingcap.com

# === SECURITY ===
CORS_ALLOW_ORIGINS=https://YOUR_ELASTIC_IP.sslip.io
SECURITY_TRUSTED_HOST_ALLOWLIST=YOUR_ELASTIC_IP.sslip.io
ENVIRONMENT=production
APP_ENV=production
LOG_LEVEL=INFO
AUTO_CREATE_SCHEMA=true
