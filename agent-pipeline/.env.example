ANTHROPIC_API_KEY=your-api-key-here

# OpenAI / Codex (OAuth-issued token — paste token value as the key)
OPENAI_OAUTH_TOKEN=your-oauth-token-here

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=your-minimax-group-id-here

# Optional: path to the iOS app repo root (defaults to parent of agent-pipeline/)
IOS_APP_ROOT=../

# Optional: max QA build/fix retry attempts (default: 5)
QA_MAX_RETRIES=5
